DATABASE_URL=postgres://radar_tcell:REPLACE_DB_PASSWORD@127.0.0.1:15433/radar_tcell?sslmode=require
DATABASE_MAX_CONNS=20
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
APP_PORT=8080
ENV=production

# Admin bootstrap fallback (используется, если в таблице admin_users нет пользователя)
ADMIN_USER=admin
ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD
ADMIN_AUTH_MODE=db_then_env
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_TTL_HOURS=8

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=REPLACE_STRONG_REDIS_PASSWORD
REDIS_DB=0

# Cache TTL
CATALOG_CACHE_TTL_SECONDS=300
TECHNOLOGY_CACHE_TTL_SECONDS=60

# Swagger (в проде лучше false)
SWAGGER_ENABLED=false

# CORS/CSRF
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=https://your-frontend.example.com

# MinIO/S3 (optional)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_PUBLIC_URL=
MINIO_USE_SSL=true
MINIO_PUBLIC_READ=false

# Observability
GRAFANA_ADMIN_PASSWORD=REPLACE_STRONG_GRAFANA_PASSWORD

