# DEV ONLY. Never use these values in production.
# Copy to .env only for local docker-compose testing.
# Production must use strong secrets and DB SSL (sslmode=require or stricter).

DATABASE_URL_DOCKER=postgres://radar_tcell:REPLACE_DB_PASSWORD@postgres:5432/radar_tcell?sslmode=disable
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
REDIS_PASSWORD=REPLACE_STRONG_REDIS_PASSWORD
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD

